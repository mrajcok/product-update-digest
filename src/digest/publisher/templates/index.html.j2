<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Cribl, Ocient & XSIAM News & Blog Posts</title>
  <script>
    if (localStorage.getItem('theme') === 'light')
      document.documentElement.setAttribute('data-theme', 'light');
  </script>
  <style>
    :root {
      --bg:               #111;
      --surface:          #1e1e1e;
      --border:           #2e2e2e;
      --border-subtle:    #252525;
      --text:             #d4d4d4;
      --text-2:           #888;
      --text-3:           #555;
      --link:             #7ab3f5;
      --link-hover:       #a0c8ff;
      --tag-bg:           #2a2a2a;
      --tag-color:        #888;
      --badge-cribl-bg:      #00cccc;
      --badge-cribl-fg:      #111;
      --badge-xsiam-bg:   #01d169;
      --badge-xsiam-fg:   #111;
      --track-bg:            #444;
      --track-active:     #5a8de0;
      --thumb:            #bbb;
      --thumb-active:     #fff;
    }
    html[data-theme="light"] {
      --bg:               #fff;
      --surface:          #fff;
      --border:           #e0e0e0;
      --border-subtle:    #eee;
      --text:             #222;
      --text-2:           #666;
      --text-3:           #999;
      --link:             #0066cc;
      --link-hover:       #004499;
      --tag-bg:           #f0f0f0;
      --tag-color:        #555;
      --badge-cribl-bg:      #00cccc;
      --badge-cribl-fg:      #111;
      --badge-xsiam-bg:   #01d169;
      --badge-xsiam-fg:   #111;
      --track-bg:            #c8d8f0;
      --track-active:     #0066cc;
      --thumb:            #0066cc;
      --thumb-active:     #fff;
    }

    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; color: var(--text); background: var(--bg); }
    h1 { border-bottom: 2px solid var(--border); padding-bottom: .5rem; margin-bottom: 1rem; }
    .top-bar { display: flex; align-items: center; margin-bottom: 1.5rem; }
    .index-hint { flex: 1; font-size: .95rem; color: var(--text-2); margin: 0; }
    .index-hint a { color: var(--link); text-decoration: none; }
    .index-hint a:hover { color: var(--link-hover); }
    .card { border: 1px solid var(--border); border-radius: 6px; padding: 1rem 1.25rem; margin-bottom: 1rem; background: var(--surface); }
    .meta { font-size: .85rem; color: var(--text-2); margin-bottom: .4rem; }
    .badge { display: inline-block; padding: .15rem .5rem; border-radius: 4px; font-size: .75rem; font-weight: 600; margin-right: .4rem; text-decoration: none; }
    .badge:hover { opacity: .85; }
    .badge-cribl   { background: var(--badge-cribl-bg);  color: var(--badge-cribl-fg); }
    .badge-ocient  { background: linear-gradient(270deg, rgba(0,235,252,1) 0%, rgba(193,227,33,1) 100%); color: #111; }
    .badge-xsiam { background: var(--badge-xsiam-bg); color: var(--badge-xsiam-fg); }
    .card h2 { margin: .25rem 0 .5rem; font-size: 1.05rem; }
    .card h2 a { color: var(--link); text-decoration: none; }
    .card h2 a:hover { color: var(--link-hover); text-decoration: underline; }
    .summary { font-size: .9rem; line-height: 1.5; color: var(--text-2); }
    .generated-at { font-size: .82rem; color: var(--text-3); margin: -.5rem 0 1.5rem; }
    .scraper-summary { margin-top: 2.5rem; border-top: 2px solid var(--border); padding-top: 1rem; }
    .scraper-summary h2 { font-size: 1rem; color: var(--text-2); margin-bottom: 1rem; }
    .scraper-block { margin-bottom: 1.25rem; }
    .scraper-block h3 { font-size: .9rem; font-weight: 600; color: var(--text); margin: 0 0 .35rem; }
    .scraper-block ul { margin: 0 0 .5rem 1.25rem; padding: 0; font-size: .82rem; color: var(--text-2); }
    .scraper-block li { margin-bottom: .2rem; }
    .scraper-block .label { font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--text-3); margin: .4rem 0 .2rem; }


    /* theme toggle */
    .theme-toggle { display: flex; align-items: center; gap: .4rem; cursor: pointer; user-select: none; }
    .theme-toggle input { position: absolute; opacity: 0; width: 0; height: 0; }
    .track { width: 38px; height: 21px; background: var(--track-bg); border-radius: 21px; position: relative; transition: background .2s; flex-shrink: 0; }
    .track::after { content: ''; position: absolute; top: 3px; left: 3px; width: 15px; height: 15px; border-radius: 50%; background: var(--thumb); transition: transform .2s, background .2s; }
    .theme-toggle input:checked ~ .track { background: var(--track-active); }
    .theme-toggle input:checked ~ .track::after { transform: translateX(17px); background: var(--thumb-active); }
    .toggle-icon { font-size: .9rem; line-height: 1; }
  </style>
</head>
<body>
  <h1>Cribl, Ocient & XSIAM News & Blog Posts</h1>
  <p class="generated-at">Generated {{ generated_at }}</p>
  <div class="top-bar">
    <p class="index-hint">Showing the {{ index_per_company }} most recent from each company — see <a href="cribl/">Cribl</a>, <a href="ocient/">Ocient</a>, and <a href="xsiam/">XSIAM</a> for more.</p>
    <label class="theme-toggle" title="Toggle light/dark theme">
      <input type="checkbox" id="theme-chk">
      <span class="track"></span>
      <span class="toggle-icon" id="theme-icon">☀</span>
    </label>
  </div>

  {% for r in updates %}
  <div class="card">
    <div class="meta">
      <a href="{{ r.company }}/" class="badge badge-{{ r.company }}">{{ r.company | upper if r.company == 'xsiam' else r.company | capitalize }}</a>
      <span>{{ r.category | replace("_", " ") }}</span>
      {% if r.published_date %}<span> · {{ r.published_date }}</span>{% endif %}
    </div>
    <h2><a href="{{ r.url }}" target="_blank" rel="noopener">{{ r.title | plaintitle }}</a></h2>
    {% if r.summary %}
    <div class="summary">{{ r.summary | markdown }}</div>
    {% endif %}
  </div>
  {% else %}
  <p>No updates yet.</p>
  {% endfor %}

  {% if scraper_infos %}
  <section class="scraper-summary">
    <h2>Coverage</h2>
    {% for info in scraper_infos %}
    <div class="scraper-block">
      <h3>{{ info.company | upper if info.company == 'xsiam' else info.company | capitalize }}</h3>
      <div class="label">Sources</div>
      <ul>
        {% for s in info.sources %}<li>{{ s }}</li>{% endfor %}
      </ul>
      <div class="label">Excluded</div>
      <ul>
        {% for e in info.exclusions %}<li class="excl">{{ e }}</li>{% endfor %}
      </ul>
    </div>
    {% endfor %}
  </section>
  {% endif %}

  <script>
    const chk = document.getElementById('theme-chk');
    const icon = document.getElementById('theme-icon');
    const saved = localStorage.getItem('theme') || 'dark';
    if (saved === 'light') { chk.checked = true; icon.textContent = '🌙'; }
    chk.addEventListener('change', function () {
      if (this.checked) {
        document.documentElement.setAttribute('data-theme', 'light');
        icon.textContent = '🌙';
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.removeAttribute('data-theme');
        icon.textContent = '☀';
        localStorage.setItem('theme', 'dark');
      }
    });
  </script>
</body>
</html>
