<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ company | capitalize }} Updates</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 860px; margin: 2rem auto; padding: 0 1rem; color: #222; }
    h1 { border-bottom: 2px solid #ddd; padding-bottom: .5rem; }
    .breadcrumb { font-size: .9rem; margin-bottom: 1.5rem; }
    .breadcrumb a { color: #0066cc; text-decoration: none; }
    h2.month { margin: 1.75rem 0 .75rem; font-size: 1rem; color: #555; text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid #eee; padding-bottom: .25rem; }
    .card { border: 1px solid #e0e0e0; border-radius: 6px; padding: 1rem 1.25rem; margin-bottom: .75rem; }
    .meta { font-size: .85rem; color: #666; margin-bottom: .4rem; }
    .tag { display: inline-block; padding: .15rem .4rem; border-radius: 4px; font-size: .75rem; background: #f0f0f0; color: #555; margin-right: .4rem; }
    .card h3 { margin: .2rem 0 .5rem; font-size: 1rem; }
    .card h3 a { color: #0066cc; text-decoration: none; }
    .card h3 a:hover { text-decoration: underline; }
    .summary { font-size: .9rem; line-height: 1.5; color: #444; }
    footer { margin-top: 2rem; font-size: .8rem; color: #999; border-top: 1px solid #eee; padding-top: .75rem; }
  </style>
</head>
<body>
  <div class="breadcrumb"><a href="../">← All Updates</a></div>
  <h1>{{ company | capitalize }} Updates</h1>

  {% for month_label, records in grouped %}
  <h2 class="month">{{ month_label }}</h2>
  {% for r in records %}
  <div class="card">
    <div class="meta">
      <span class="tag">{{ r.category | replace("_", " ") }}</span>
      {% if r.published_date %}<span>{{ r.published_date }}</span>{% endif %}
    </div>
    <h3><a href="{{ r.url }}" target="_blank" rel="noopener">{{ r.title }}</a></h3>
    {% if r.summary %}
    <p class="summary">{{ r.summary }}</p>
    {% endif %}
  </div>
  {% endfor %}
  {% else %}
  <p>No updates yet.</p>
  {% endfor %}

  <footer>Generated {{ generated_at }}</footer>
</body>
</html>
