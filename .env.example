OPENROUTER_API_KEY=sk-or-...
OPENROUTER_SUMMARIZATION_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_DRY_RUN_SUMMARIZATION_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Optional: use a local Ollama server instead of OpenRouter for summarization.
# When OLLAMA_BASE_URL is set it takes precedence over OpenRouter for all summarization.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_SUMMARIZATION_MODEL=gemma3:4b        # must match a model pulled via: ollama pull <model>
# OLLAMA_DRY_RUN_SUMMARIZATION_MODEL=         # defaults to OLLAMA_SUMMARIZATION_MODEL
SQLITE_DB_PATH=data/product_updates.db
GITHUB_TOKEN=ghp_...
GITHUB_REPO=username/product-updates
GITHUB_PAGES_BRANCH=gh-pages
MAX_ARTICLE_AGE_DAYS=30
LOG_LEVEL=INFO
