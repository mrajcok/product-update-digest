OPENROUTER_API_KEY=sk-or-...
OPENROUTER_SUMMARIZATION_MODEL=google/gemma-3-27b-it
OPENROUTER_STAGE_SUMMARIZATION_MODEL=         # defaults to OPENROUTER_SUMMARIZATION_MODEL
OPENROUTER_RAG_MODEL=                         # defaults to OPENROUTER_SUMMARIZATION_MODEL
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_DIMENSIONS=4096
MAX_SOURCE_TEXT_CHARS=15000      # chars of raw text fed to the embedding model (whole-doc vector)
SUMMARIZER_CONTENT_CHARS=15000   # chars of raw text sent to the summarization LLM
SEARCH_SCORE_THRESHOLD=0.10      # minimum cosine similarity to return a search result (0–1)
RAG_CHUNK_SIZE_CHARS=2000        # chars per RAG chunk
RAG_CHUNK_OVERLAP_CHARS=200      # overlap between consecutive chunks

# Optional: use a local Ollama server instead of OpenRouter for summarization.
# When OLLAMA_BASE_URL is set it takes precedence over OpenRouter for all summarization.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_SUMMARIZATION_MODEL=gemma3:4b        # must match a model pulled via: ollama pull <model>
# OLLAMA_STAGE_SUMMARIZATION_MODEL=           # defaults to OLLAMA_SUMMARIZATION_MODEL
# OLLAMA_RAG_MODEL=                           # defaults to OLLAMA_SUMMARIZATION_MODEL
SQLITE_DB_PATH=data/product_updates.db
GITHUB_TOKEN=ghp_...
GITHUB_REPO=username/product-updates
GITHUB_PAGES_BRANCH=gh-pages
MAX_ARTICLE_AGE_DAYS=30
INDEX_PAGE_LIMIT=10
LOG_LEVEL=INFO
